[Desktop Entry]
Version=1.0
Name=ttyx_
Comment=A tiling terminal for Linux, forked from Tilix
Keywords=shell;prompt;command;commandline;cmd;terminal;tiling;
Exec=ttyx
Terminal=false
Type=Application
StartupNotify=true
Categories=System;TerminalEmulator;X-GNOME-Utilities;
Icon=io.github.gwelr.ttyx
DBusActivatable=true
Actions=new-window;new-session;preferences;

[Desktop Action new-window]
Name=New Window
Exec=ttyx --action=app-new-window

[Desktop Action new-session]
Name=New Session
Exec=ttyx --action=app-new-session

[Desktop Action preferences]
Name=Preferences
Exec=ttyx --preferences
